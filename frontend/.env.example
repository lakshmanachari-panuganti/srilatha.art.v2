# ─────────────────────────────────────────────────────────────────────────────
# Frontend — public env vars (exposed to the browser).
#
# Production values are injected at build time by .github/workflows/deploy-
# frontend-*.yml; values listed here are the local-dev defaults. Copy this
# file to .env.local and replace placeholders as needed.
# ─────────────────────────────────────────────────────────────────────────────

# Azure Functions API base. Local dev points at the Functions host on :7071;
# the deploy workflow overrides this with the per-env Function App URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:7071/api

# Blob-storage base for site assets (seed images + admin uploads).
# Per-environment values:
#   DEV → https://stsrilathaartv2dev.blob.core.windows.net/products
#   PRD → https://stsrilathaartv2prd.blob.core.windows.net/products
NEXT_PUBLIC_ASSET_BASE_URL=https://stsrilathaartv2dev.blob.core.windows.net/products

# Canonical site URL (used for absolute links / OpenGraph).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Razorpay client key (publishable). Secret lives only in the Function App.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
