    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@azure/functions": "^4.5.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
