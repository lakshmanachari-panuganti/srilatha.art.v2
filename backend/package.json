{
  "name": "srilatha-art-backend",
  "version": "1.0.0",
  "description": "Srilatha Art Backend API - Azure Functions v4",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "prestart": "npm run build",
    "start": "func start",
    "dev": "concurrently \"tsc -w\" \"func start\"",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@azure/data-tables": "^13.2.2",
    "@azure/functions": "^4.5.0",
    "@azure/identity": "^4.2.1",
    "@azure/storage-blob": "^12.17.0",
    "@azure/storage-queue": "^12.17.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^9.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.1",
    "@types/uuid": "^9.0.8",
    "concurrently": "^8.2.2",
    "rimraf": "^5.0.10",
    "typescript": "^5.4.5"
  }
}
